<style>
    .blog-detail-gallery-carousel img {
        max-height: 480px;
    }


    /* Custom 5-column layout using 20% width */
    .col-5ths {
        width: 20%;
        float: left;
        padding: 15px;
    }

    @media (max-width: 991px) {
        .col-5ths {
            width: 33.33%;
        }
    }

    @media (max-width: 767px) {
        .col-5ths {
            width: 50%;
        }
    }

    @media (max-width: 575px) {
        .col-5ths {
            width: 100%;
        }
    }

    .mNewFont {
        font-size: 20px; /* Change this value to your preferred size */
    }


    /* Video Gallary CSS*/
    .video-modal {
        display: none;
        position: fixed;
        z-index: 9999;
        inset: 0;
        background: rgba(0,0,0,0.75);
        align-items: center;
        justify-content: center;
    }

    .video-modal-content {
        position: relative;
        width: 80%;
        max-width: 900px;
        background: transparent;
    }

    /* .video-modal video {
        width: 100%;
        border-radius: 12px;
    }*/

    .close-modal {
        position: absolute;
        top: -35px;
        right: 0;
        font-size: 32px;
        color: #fff;
        cursor: pointer;
    }

    .video-gallery-section {
        padding: 50px 0;
        background: transparent; /* ✅ No background */
        overflow: hidden;
    }

    .gallery-title {
        text-align: center;
        font-size: 28px;
        color: inherit; /* ✅ Inherits page text color */
        margin-bottom: 25px;
        font-weight: 600;
    }

    .video-label {
        margin-top: 8px;
        text-align: center;
        background: transparent;
    }

        .video-label .name {
            font-size: 14px;
            font-weight: 600;
            color: inherit;
        }

        .video-label .trade {
            font-size: 12px;
            opacity: 0.75;
        }

    .video-marquee {
        width: 100%;
        overflow: hidden;
        position: relative;
    }

    .video-track {
        display: flex;
        width: max-content;
        gap: 20px;
        animation: scroll-left 40s linear infinite;
    }


    .video-card {
        min-width: 300px;
        height: 180px;
        border-radius: 16px;
        overflow: hidden;
        position: relative;
        background: transparent; /* ✅ No background */
        box-shadow: 0 10px 25px rgba(0,0,0,0.25); /* Optional – remove if not needed */
        cursor: pointer;
        transition: transform 0.4s ease;
    }

        .video-card:hover {
            transform: scale(1.05);
        }

        .video-card video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            background: transparent; /* ✅ No black flash */
        }

    /* Marquee animation */
    @keyframes scroll-left {
        0% {
            transform: translateX(0);
        }

        100% {
            transform: translateX(-50%);
        }
    }

    /*  Video Gallary CSS*/

    /* -----Simulate video----*/
    .video-card video {
        width: 100%;
        height: 180px;
        object-fit: cover;
    }

    /* ONLY for video 1, 8, 9 thumbnails */
    .video-card.tall-thumb video {
        height: 200px; /* slightly taller */
        object-fit: contain; /* 🔥 no cutting */
        background: #000; /* clean padding */
    }


    .video-card video {
        width: 100%;
        height: 200px;
        object-fit: cover;
        display: block;
    }

    .video-info {
        position: absolute;
        bottom: 0;
        width: 100%;
        padding: 8px;
        background: linear-gradient(to top, rgba(0,0,0,0.8), rgba(0,0,0,0));
        color: #fff;
        text-align: left;
    }

    .student-name {
        font-size: 14px;
        font-weight: 600;
        margin: 0;
    }

    .student-trade {
        font-size: 12px;
        margin: 0;
        color: #ddd;
    }


    /* Default popup video */
    /*.video-modal video {
        max-width: 100%;
        max-height: 80vh;*/ /* 🔥 prevents window overflow */
