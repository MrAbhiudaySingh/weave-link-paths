<script>
    particlesJS('particles-js',
        {
            "particles": {
                "number": {
                    "value": 80,
                    "density": {
                        "enable": true,
                        "value_area": 800
                    }
                },
                "color": {
                    "value": "#ffffff"
                },
                "shape": {
                    "type": "circle",
                    "stroke": {
                        "width": 0,
                        "color": "#000000"
                    },
                    "polygon": {
                        "nb_sides": 5
                    },
                    "image": {
                        "src": "img/github.svg",
                        "width": 100,
                        "height": 100
                    }
                },
                "opacity": {
                    "value": 0.5,
                    "random": false,
                    "anim": {
                        "enable": false,
                        "speed": 1,
                        "opacity_min": 0.1,
                        "sync": false
                    }
                },
                "size": {
                    "value": 5,
                    "random": true,
                    "anim": {
                        "enable": false,
                        "speed": 40,
                        "size_min": 0.1,
                        "sync": false
                    }
                },
                "line_linked": {
                    "enable": true,
                    "distance": 150,
                    "color": "#ffffff",
                    "opacity": 0.4,
                    "width": 1
                },
                "move": {
                    "enable": true,
                    "speed": 6,
                    "direction": "none",
                    "random": false,
                    "straight": false,
                    "out_mode": "out",
                    "attract": {
                        "enable": false,
                        "rotateX": 600,
                        "rotateY": 1200
                    }
                }
            },
            "interactivity": {
                "detect_on": "canvas",
                "events": {
                    "onhover": {
                        "enable": true,
                        "mode": "repulse"
                    },
                    "onclick": {
                        "enable": true,
                        "mode": "push"
                    },
                    "resize": true
                },
                "modes": {
                    "grab": {
                        "distance": 400,
                        "line_linked": {
                            "opacity": 1
                        }
                    },
                    "bubble": {
                        "distance": 400,
                        "size": 40,
                        "duration": 2,
                        "opacity": 8,
                        "speed": 3
                    },
                    "repulse": {
                        "distance": 200
                    },
                    "push": {
                        "particles_nb": 4
                    },
                    "remove": {
                        "particles_nb": 2
                    }
                }
            },
            "retina_detect": true,
            "config_demo": {
                "hide_card": false,
                "background_color": "#b61924",
                "background_image": "",
                "background_position": "50% 50%",
                "background_repeat": "no-repeat",
                "background_size": "cover"
            }
        }

    );
    $(document).ready(function () {
        'use strict';
        if ($.isFunction($.fn.counterUp)) {
            $('.counter').counterUp({
                delay: 10,
                time: 2000
            });
        }
    });


    const videoTrack = document.querySelector('.video-track');
    const videos = document.querySelectorAll('.video-card video');

    videos.forEach(video => {

        // Hover → autoplay
        video.addEventListener('mouseenter', () => {
            videoTrack.style.animationPlayState = 'paused';
            video.play();
        });

        // Mouse leave → stop video & resume marquee
        video.addEventListener('mouseleave', () => {
            video.pause();
            video.currentTime = 0;
            videoTrack.style.animationPlayState = 'running';
        });

        // Click → play with controls
        video.addEventListener('click', () => {
            video.setAttribute('controls', 'controls');
            video.muted = false;
            video.play();
        });
    });

    const modal = document.getElementById('videoModal');
    const modalVideo = document.getElementById('modalVideo');
    const closeBtn = document.querySelector('.close-modal');
    const track = document.querySelector('.video-track');

    document.querySelectorAll('.video-card video').forEach(video => {

        // Hover play
        video.addEventListener('mouseenter', () => {
            track.style.animationPlayState = 'paused';
            video.play();
        });

        video.addEventListener('mouseleave', () => {
            video.pause();
            video.currentTime = 0;
            track.style.animationPlayState = 'running';
        });

        // Click → popup
        video.addEventListener('click', (e) => {
            e.stopPropagation();
            modal.style.display = 'flex';
            modalVideo.src = video.currentSrc;
            modalVideo.play();
        });
    });

    closeBtn.onclick = () => {
        modal.style.display = 'none';
        modalVideo.pause();
        modalVideo.src = '';
    };

    modal.onclick = () => closeBtn.onclick();
</script>


