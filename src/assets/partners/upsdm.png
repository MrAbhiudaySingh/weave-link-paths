    <script>
        $(document).ready(function () {
            'use strict';
            var taregtminutes = 5;
            function countdown() {
                var minutes = $('.minutes').text().replace(':00', '');
                if (taregtminutes == 0) {
                    $('#btnResendOTP').removeClass('hidden');
                    clearInterval(interval);
                    return;
                }
                taregtminutes = taregtminutes - 1;
                $('.minutes').text(taregtminutes + ':00');
            };
            var interval = setInterval(countdown, 1000);
            $('html, body').animate({ scrollTop: 0 }, '300');
        });
        $(document).on("click", "#btnResendOTP", function (e) {
            e.preventDefault();
            alert('Resend OTP Successfully..');
        });
