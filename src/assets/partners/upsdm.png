    <style>
        .breadcrumb {
            float: left;
            width: 100%;
            background-color: transparent;
            -webkit-border-radius: 0;
            border-radius: 0;
            margin-bottom: 0;
            padding: 10px 0;
            margin-top: 10px;
        }

            .breadcrumb > li {
                font-family: Poppins;
                color: #0e82b9;
                font-size: 18px;
                font-weight: 600;
            }

            .breadcrumb > active {
                color: #c30707 !important
            }


/* Floating Toggle Button */
        #chatToggle {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 65px;
            height: 65px;
            background: linear-gradient(45deg, #28a745, #dc3545);
            color: #fff;
            font-size: 30px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 6px 18px rgba(0,0,0,0.3);
            z-index: 9999;
        }

        /* Main Chat Container */
        #chatbot-container {
            width: 360px;
            height: 520px;
            position: fixed;
            bottom: 100px;
            right: 20px;
            background: #fff;
            border-radius: 15px;
            box-shadow: 0 12px 30px rgba(0,0,0,0.35);
            z-index: 9999;
            display: none; /* important */
            flex-direction: column;
            overflow: hidden;
        }

        /* Header */
        .chat-header {
            height: 70px;
            background: linear-gradient(45deg, #28a745, #dc3545);
            color: white;
            padding: 10px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
        }

        .robot-img {
            width: 40px;
            margin-right: 8px;
        }

        #closeChat {
            cursor: pointer;
            font-size: 18px;
        }

        /* Chat Scroll Area */
        #chatbox {
            flex: 1;
            overflow-y: auto;
            padding: 10px;
            background: #f8f9fa;
            display: flex;
            flex-direction: column;
            min-height: 0;
        }

        /* Input Area */
        .chat-input-area {
            height: 60px;
            display: flex;
            border-top: 1px solid #ddd;
            background: #fff;
            flex-shrink: 0;
        }

        #userMessage {
            flex: 1;
            border: none;
            padding: 12px;
            outline: none;
        }

        #sendBtn {
            width: 60px;
            background: #dc3545;
            border: none;
            color: white;
            cursor: pointer;
        }

        /* Messages */
        .user {
            align-self: flex-end;
            background: #28a745;
            color: white;
            padding: 8px 12px;
            border-radius: 15px;
            margin: 6px 0;
            max-width: 75%;
            word-wrap: break-word;
        }

        .bot {
            align-self: flex-start;
            background: #e9ecef;
            color: #333;
            padding: 8px 12px;
            border-radius: 15px;
            margin: 6px 0;
            max-width: 75%;
            word-wrap: break-word;
        }

        /* Scrollbar */
        #chatbox::-webkit-scrollbar {
            width: 6px;
        }

        #chatbox::-webkit-scrollbar-thumb {
            background: #bbb;
            border-radius: 10px;
        }


    </style>
    <script src="/Content/MainJS?v=bjNvNYruWZct4lOblNuhZulxe_M9QoR1pxP31vh_KA01"></script>

